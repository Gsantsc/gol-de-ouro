# API FOOTBALL ENV
# Server/backend only. Never prefix API_FOOTBALL_KEY with NEXT_PUBLIC or EXPO_PUBLIC.
MATCHES_PROVIDER=api-football
MATCHES_FALLBACK_PROVIDER=static-wc2026
API_FOOTBALL_KEY=replace-with-api-football-key
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_INCLUDE_DETAILS=false
API_FOOTBALL_WORLD_CUP_LEAGUE_ID=1
API_FOOTBALL_WORLD_CUP_SEASON=2026
API_FOOTBALL_MAX_PLAYER_TEAMS=48
API_FOOTBALL_MAX_PLAYER_PAGES=1

