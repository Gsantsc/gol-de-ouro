NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
CRON_SECRET=replace-with-long-random-secret
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# API-FOOTBALL INTEGRATION
# Configure to use real football data from API-Football
# Get your API key at: https://api-football.com/
API_FOOTBALL_KEY=your_api_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
MATCHES_PROVIDER=api-football
API_FOOTBALL_INCLUDE_DETAILS=true
API_FOOTBALL_SEASON=2025
MATCHES_PROVIDER_TIMEZONE=America/Sao_Paulo

# WC2026 API INTEGRATION
# Configure to use World Cup 2026 data from WC2026 API
# Get your API key at: https://api.wc2026api.com/docs
WC2026_API_KEY=your_wc2026_api_key_here
# To use WC2026 provider, set MATCHES_PROVIDER=wc2026
