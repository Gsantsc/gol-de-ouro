{
  "name": "gol-de-ouro",
  "version": "0.1.0",
  "private": true,
  "main": "apps/mobile/index.ts",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "postcss": "^8.5.15",
    "shell-quote": "^1.8.4",
    "uuid": "^11.1.1",
    "@next/eslint-plugin-next": {
      "glob": "10.5.0"
    }
  },
  "scripts": {
    "admin": "npm run dev:admin -w @gol-de-ouro/admin",
    "dashboard": "npm run dev:dashboard -w @gol-de-ouro/admin",
    "user": "npm run dashboard",
    "build": "npm run build --workspaces --if-present",
    "postbuild": "node scripts/vercel-admin-output.cjs",
    "vercel:admin": "node scripts/build-vercel-admin.cjs",
    "vercel:user": "node scripts/build-vercel-user.cjs",
    "dev": "npm run admin",
    "expo": "npm run start -w @gol-de-ouro/mobile",
    "lint": "npm run lint --workspaces --if-present",
    "mobile": "npm run start -w @gol-de-ouro/mobile",
    "mobile:check:beta-env": "npm run check:beta-env -w @gol-de-ouro/mobile",
    "mobile:build:apk": "npm run build:android:apk -w @gol-de-ouro/mobile",
    "mobile:build:apk:local": "npm run build:android:apk:local -w @gol-de-ouro/mobile",
    "mobile:build:aab": "npm run build:android:aab -w @gol-de-ouro/mobile",
    "mobile:submit:beta": "npm run submit:android:beta -w @gol-de-ouro/mobile",
    "pwa:export": "npm run export:web -w @gol-de-ouro/mobile",
    "seed:demo-user-flow": "node scripts/demo-user-flow.cjs seed",
    "seed:demo-user-flow:dry-run": "node scripts/demo-user-flow.cjs seed --dry-run",
    "cleanup:demo-user-flow": "node scripts/demo-user-flow.cjs cleanup",
    "cleanup:demo-user-flow:dry-run": "node scripts/demo-user-flow.cjs cleanup --dry-run",
    "cleanup:app-data": "node scripts/cleanup-app-data.cjs",
    "diagnose:auth-users": "node scripts/diagnose-auth-users.cjs",
    "repair:approved-auth-users": "node scripts/confirm-approved-auth-users.cjs",
    "capture:auth-login-ui": "node scripts/capture-auth-login-ui.cjs",
    "qa:user-flow": "node scripts/qa-user-flow.cjs",
    "qa:user-flow:keep": "node scripts/qa-user-flow.cjs --keep",
    "jobs:matches": "node scripts/jobs-matches.cjs",
    "jobs:matches:dry-run": "node scripts/jobs-matches.cjs --dry-run",
    "seed:players:wc2026": "node scripts/seed-players-world-cup-2026.cjs",
    "seed:players:wc2026:dry-run": "node scripts/seed-players-world-cup-2026.cjs --dry-run",
    "seed:players:api-football": "node scripts/seed-players-api-football.cjs",
    "seed:players:api-football:dry-run": "node scripts/seed-players-api-football.cjs --dry-run",
    "validate:match-rules": "node scripts/validate-match-rules.cjs",
    "validate:world-cup-times": "node scripts/validate-world-cup-times.cjs",
    "stop:admin": "node scripts/stop-port.cjs 3000",
    "stop:dashboard": "node scripts/stop-port.cjs 3002",
    "stop:mobile": "node scripts/stop-port.cjs 8081",
    "stop:dev": "node scripts/stop-port.cjs 3000 3002 8081",
    "supabase:reset": "supabase db reset",
    "supabase:start": "supabase start",
    "supabase:status": "supabase status",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "import:world-cup-2026": "node scripts/import-world-cup-2026.cjs",
    "import:world-cup-2026:dry-run": "node scripts/import-world-cup-2026.cjs --dry-run",
    "sync:live-results": "node scripts/sync-live-results.cjs && node scripts/jobs-matches.cjs",
    "sync:live-results:dry-run": "node scripts/sync-live-results.cjs --dry-run && node scripts/jobs-matches.cjs --dry-run",
    "simulate:world-cup-2026": "node scripts/simulate-world-cup-2026.cjs",
    "sync:fixtures:api-football": "node scripts/sync-matches-api-football.cjs",
    "sync:fixtures:api-football:dry-run": "node scripts/sync-matches-api-football.cjs --dry-run",
    "import:world-cup-2026:linked": "node scripts/import-world-cup-2026-linked.cjs",
    "import:world-cup-2026:linked:dry-run": "node scripts/import-world-cup-2026-linked.cjs --dry-run",
    "sync:espn": "node scripts/sync-espn.cjs && node scripts/jobs-matches.cjs",
    "sync:espn:dry-run": "node scripts/sync-espn.cjs --dry-run && node scripts/jobs-matches.cjs --dry-run",
    "simulate:espn": "node scripts/simulate-espn-scenarios.cjs",
    "simulate:auto-sync": "node scripts/simulate-auto-sync-scenarios.cjs",
    "simulate:auth-flow": "node scripts/simulate-auth-flow.cjs",
    "beta:check": "node scripts/beta-readiness-check.cjs"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "concurrently": "^9.1.2",
    "supabase": "^2.103.0",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "next": "^16.2.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
